# Cerebras API Key — get from https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Model to use (Cerebras supports these)
# llama-3.3-70b       ← recommended (fastest, best quality)
# llama-3.1-8b        ← lightweight option
CEREBRAS_MODEL=llama-3.3-70b

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./ratefluencer.db
# DATABASE_URL=postgresql://user:password@localhost/ratefluencer
